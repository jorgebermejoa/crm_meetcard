# Firebase secrets template — CRM Meetcard
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env.local y rellena los valores reales.
# .env.local NUNCA debe subirse a Git.
#
# Uso:
#   flutter run -d chrome --dart-define-from-file=.env.local
#   flutter build web  --dart-define-from-file=.env.local
#
# En CI/CD (Firebase Hosting GitHub Action), configura estas variables
# como secrets del repositorio y pásalas con --dart-define en el build step.
# ─────────────────────────────────────────────────────────────────────────────

FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_SENDER_ID=
